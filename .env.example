# Business Dashboard — Environment Variables
# Copy this file to .env and fill in your keys

# Stripe (required for Revenue module)
# Get your key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Instagram (optional — for Content module)
# See setup-guides/instagram-token.md for instructions
IG_ACCESS_TOKEN=
IG_USER_ID=
