# Business Dashboard — Environment Variables
# Copy this file to .env and fill in your keys
# Only fill in the ones you need — the rest will use manual data

# ── Stripe (Revenue module) ──
# Get your key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Instagram (Content module) ──
# See setup-guides/instagram-token.md for instructions
IG_ACCESS_TOKEN=
IG_USER_ID=

# ── GoHighLevel (Clients + Pipeline modules) ──
# See setup-guides/ghl-api-key.md for instructions
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_CLIENT_TAG=client
GHL_MRR_FIELD=mrr
GHL_PIPELINE_ID=

# ── Instantly.ai (Outreach module) ──
# See setup-guides/instantly-api-key.md for instructions
INSTANTLY_API_KEY=

# ── Slack (enhances Client last-contact tracking) ──
# See setup-guides/slack-bot-token.md for instructions
SLACK_BOT_TOKEN=
SLACK_CLIENT_CHANNELS={}
